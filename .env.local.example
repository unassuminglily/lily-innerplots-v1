# ── Sanity ───────────────────────────────────────────────────────────────────
# Find both values at https://www.sanity.io/manage → your project → Settings → API

# Your Sanity project ID (already used in studio-lilysinnerplots/sanity.config.ts)
NEXT_PUBLIC_SANITY_PROJECT_ID=qab4bxpf

# The dataset to query — "production" unless you created a separate one
NEXT_PUBLIC_SANITY_DATASET=production

# ── Instructions ─────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local  (git-ignored — never commit .env.local)
# 2. Fill in the values above
# 3. Restart `npm run dev` after any change
